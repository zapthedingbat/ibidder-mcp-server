{
  "name": "ibidder-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for searching auction lots on i-bidder.com via CamoFox stealth browser.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "ibidder-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:stdio": "tsx src/index.ts --transport stdio",
    "dev:http": "tsx src/index.ts --transport http",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "inspector": "npx @modelcontextprotocol/inspector"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^5.0.0",
    "undici": "^6.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.0"
  }
}
